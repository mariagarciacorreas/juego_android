<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher_parlamon"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_parlamon_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ProyectoParlamon">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ActividadJuego"
            android:configChanges="keyboardHidden|orientation|screenSize|screenLayout|smallestScreenSize|density"
            android:exported="false"
            android:resizeableActivity="false"
            android:screenOrientation="landscape"> <!-- Soporte de notch para Huawei / Xiaomi y otros fabricantes -->
            <meta-data
                android:name="android.notch_support"
                android:value="true" />
        </activity>
    </application>
</manifest>